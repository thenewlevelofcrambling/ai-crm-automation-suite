# Скопируй в .env и задай свои значения (.env в git не попадает — см. .gitignore)
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change_me_please

# Supabase (Postgres + pgvector) — постоянное векторное хранилище для RAG.
# Берётся в Supabase → Project Settings → API. В n8n заводится как Supabase credential.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
